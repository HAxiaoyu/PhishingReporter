{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=PhishingReporter;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  "Exchange": {
    "EwsUrl": "https://exchange.company.com/EWS/Exchange.asmx",
    "Username": "service-account@company.com",
    "Password": "",
    "Domain": "",
    "ArchiveFolderName": "Phishing Reports",
    "ArchiveMailbox": "phishing-archive@company.com"
  },

  "FileStorage": {
    "BasePath": "./eml-storage",
    "MaxFileSizeBytes": 52428800,
    "AllowedExtensions": [".eml", ".msg"]
  },

  "Notification": {
    "SmtpHost": "smtp.company.com",
    "SmtpPort": 25,
    "SmtpUseSSL": false,
    "FromAddress": "phishing-reporter@company.com",
    "SecurityTeamEmail": "security-team@company.com",
    "TeamsWebhookUrl": ""
  },

  "ApiSettings": {
    "ApiKey": "",
    "RateLimitPerMinute": 60,
    "MaxRequestSizeBytes": 10485760
  },

  "Cors": {
    "AllowedOrigins": [
      "https://phishing-report.internal",
      "https://intranet.company.com"
    ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "PhishingReporter": "Debug"
    }
  },

  "AllowedHosts": "*",

  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      },
      "Https": {
        "Url": "https://localhost:5001"
      }
    }
  }
}