<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- API 配置 -->
    <!-- 后端 API 地址 - 请根据实际部署修改 -->
    <add key="ApiBaseUrl" value="https://phishing-report.internal/api" />

    <!-- API 密钥 - 用于认证，可选 -->
    <add key="ApiKey" value="" />

    <!-- 请求超时时间（秒） -->
    <add key="RequestTimeoutSeconds" value="30" />

    <!-- 日志配置 -->
    <!-- 日志文件路径 - 空值则使用默认路径 -->
    <add key="LogFilePath" value="" />

    <!-- 日志级别: Debug, Info, Warning, Error -->
    <add key="LogLevel" value="Info" />

    <!-- 功能配置 -->
    <!-- 是否自动标记已上报邮件 -->
    <add key="EnableAutoArchive" value="true" />

    <!-- 存档文件夹名称 -->
    <add key="ArchiveFolderPath" value="已上报钓鱼邮件" />
  </appSettings>

  <system.net>
    <settings>
      <!-- 最大连接数 -->
      <servicePointManager expect100Continue="false" maxConnection="100"/>
    </settings>
  </system.net>
</configuration>